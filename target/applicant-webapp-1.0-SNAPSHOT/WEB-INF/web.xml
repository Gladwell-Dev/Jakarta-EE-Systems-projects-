<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/javaee" version="5.0">
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.apd.internship.web.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/auth</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.apd.internship.web.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ApplyServlet</servlet-name>
        <servlet-class>com.apd.internship.web.ApplyServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ApplyServlet</servlet-name>
        <url-pattern>/apply</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ProgressServlet</servlet-name>
        <servlet-class>com.apd.internship.web.ProgressServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProgressServlet</servlet-name>
        <url-pattern>/progress</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>StatusUpdateServlet</servlet-name>
        <servlet-class>com.apd.internship.web.StatusUpdateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StatusUpdateServlet</servlet-name>
        <url-pattern>/statusupdate</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>
</web-app>